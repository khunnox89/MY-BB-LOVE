<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D Love Heart</title>
    <style>
        body {
            background-color: #000;
            overflow: hidden;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .heart {
            position: relative;
            font-size: 50px;
            color: #ff69b4;
            animation: pulse 1.5s infinite;
        }
        @keyframes pulse {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.1);
            }
        }
        .particle {
            position: absolute;
            color: #fff;
            animation: blink 1.5s infinite;
        }
        @keyframes blink {
            0%, 100% {
                opacity: 0;
            }
            50% {
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <div class="heart">I love you my BB ❤️</div>
    <script>
        const heart = document.querySelector('.heart');
        let particles = [];
        // Particle generation logic here
        function createParticle() {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.innerText = '❤️';
            document.body.appendChild(particle);
            particles.push(particle);
        }
        setInterval(createParticle, 300);
        // Animation loop logic here
        function animate() {
            particles.forEach(particle => {
                // Particle animation logic here
            });
            requestAnimationFrame(animate);
        }
        animate();
    </script>
</body>
</html>
